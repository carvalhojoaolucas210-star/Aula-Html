# ============================================================
#  Portal Uberlândia Notícias — Variáveis de Ambiente
#  Renomeie este arquivo para .env e preencha os valores.
#  NUNCA faça commit deste arquivo no Git.
#  Adicione ".env" no seu .gitignore.
# ============================================================

# ── Segurança Flask ──────────────────────────────────────────
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-secreta-forte

# ── E-mail (SMTP) ────────────────────────────────────────────
# Deixe MAIL_USER em branco para usar o modo simulação (imprime no terminal).
#
# Para Gmail:
#   1. Ative a verificação em 2 etapas em myaccount.google.com
#   2. Crie uma "Senha de app" em myaccount.google.com/apppasswords
#   3. Use os 16 caracteres gerados em MAIL_PASSWORD (nunca sua senha normal)
#
# Para SendGrid:
#   MAIL_HOST=smtp.sendgrid.net
#   MAIL_USER=apikey
#   MAIL_PASSWORD=<sua_API_Key_SendGrid>

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=carvalhojoaolucas210@gmail.com
MAIL_PASSWORD=rbgahaliobzedetc
MAIL_FROM=Portal Uberlandia Noticias
